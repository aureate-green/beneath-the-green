---
const { entries = [], base = '' } = Astro.props;
const sorted = [...entries].sort((a,b) => (a.data.order ?? 999) - (b.data.order ?? 999) || a.data.title.localeCompare(b.data.title));
---
<div class="index-grid">
  {sorted.map((entry) => (
    <a class="card" href={`${base}/${entry.id.replace(/\.mdx?$/, '')}/`}>
      <h3>{entry.data.title}</h3>
      {entry.data.description && <p>{entry.data.description}</p>}
    </a>
  ))}
</div>
