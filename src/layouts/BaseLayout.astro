---
const {
  title = 'Beneath the Green',
  description = 'Modern southern gothic cosmic horror. Our world under pressure.',
} = Astro.props;
const nav = [
  ['/', 'Threshold'],
  ['/world/', 'World Info'],
  ['/stories/', 'Stories'],
  ['/seeds/', 'Seeds'],
  ['/how-to/', 'For Your AI'],
  ['/about/', 'About'],
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title === 'Beneath the Green' ? title : `${title} · Beneath the Green`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Special+Elite&family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div class="weather" aria-hidden="true"></div>
    <div class="site-shell">
      <aside class="left-frame">
        <a class="brand" href="/" aria-label="Beneath the Green home">
          <span class="sigil">☉</span>
          <span class="brand-text">Beneath<br/>the Green</span>
        </a>
        <p class="tagline">our world<br/>under pressure</p>
        <nav aria-label="Primary navigation">
          {nav.map(([href, label]) => <a class={Astro.url.pathname === href || (href !== '/' && Astro.url.pathname.startsWith(href)) ? 'active' : ''} href={href}>{label}</a>)}
        </nav>
        <div class="side-note">
          <p>Written in the margin of a county map. Found damp. Still legible.</p>
        </div>
      </aside>
      <main class="main-frame">
        <slot />
      </main>
    </div>
  </body>
</html>
